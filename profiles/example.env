# ─────────────────────────────────────────────────────────────────────────────
# the-gitfather — example profile (copy this into your OWN repo and edit)
#
# A profile holds everything project-specific; the actual DB/R2 *credentials* come
# from the environment (GitHub secrets), never from here. Loaded by the scripts via
# $PROFILE, e.g.:
#
#   PROFILE=profiles/example.env npx tsx scripts/backup-pg-to-r2.ts
#
# In CI you keep this file in your consuming repo and point the caller workflow's
# `profile:` input at it (see README → "Wiring a consuming repo").
#
# Every task validates these vars (zod) at startup and fails fast with one aggregated
# report on any missing/malformed value. To check a freshly-wired consumer end-to-end
# (config + live R2/Postgres/Slack/gh probes, read-only):
#
#   PROFILE=profiles/example.env npm run doctor -- all
#
# See README → "Config validation & doctor" for the grammars.
#
# Credentials expected in the environment (NOT set here):
#   PG_BACKUP_DATABASE_URL   postgres://USER:PW@HOST:5432/DB?sslmode=require
#                            (if your provider has a pooler, use the SESSION pooler)
#   R2_ACCOUNT_ID / R2_BUCKET / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY
#   SLACK_BOT_TOKEN          (optional) xoxb-… (scope chat:write) — enables the daily Slack status row
#   SLACK_CHANNEL            (optional) channel id (C…) to post the status row in
#   HEARTBEAT_URL            (optional) dead-man's-switch ping hit on success
# ─────────────────────────────────────────────────────────────────────────────

# Object-key layout: <BACKUP_PREFIX>/<tier>/<FILE_BASENAME>-<stamp>.<ext>
BACKUP_PREFIX="pg/example"
FILE_BASENAME="example"

# Full custom-format dump, restorable without the source's roles. Tune the flags to
# your database (e.g. add --exclude-schema=… to drop a platform-managed schema).
PG_DUMP_FLAGS="-Fc --no-owner --no-privileges"

# none | age | aes-gcm   (age = client-side encryption; requires AGE_RECIPIENT for
# backups and AGE_IDENTITY for the restore drill. aes-gcm is not implemented yet.)
ENCRYPTION="none"

# ── Backup-time integrity ────────────────────────────────────────────────────
BACKUP_SHA256="1"             # record a SHA-256 of the uploaded object (the durable hash-verify baseline)
BACKUP_VALIDATE_STRUCTURE="1" # pg_restore -l TOC check before declaring success (ENCRYPTION=none)
BACKUP_VERIFY="0"             # opt-in: re-download + (decrypt) + pg_restore -l after upload (only age-mode
                              # structural check; for age it needs AGE_IDENTITY in the backup job's env)

# Postgres client major version — must be >= the server you dump.
PG_CLIENT_MAJOR="17"

# ── GFS tiering (all computed in UTC) ────────────────────────────────────────
# Every run writes to 2hourly/. The run whose UTC hour == ANCHOR_HOUR_UTC is also
# promoted (server-side copy) to daily/, plus weekly/ on Sundays, plus monthly/ on the 1st.
ANCHOR_HOUR_UTC="16"

# ── Restore drill / durable verification ─────────────────────────────────────
DRILL_SENTINEL_TABLE="your_largest_table"   # public.<table>; gated against live row count
DRILL_EXTRA_TABLES="another_table a_third_table"   # asserted simply non-empty (space-separated)
DRILL_EXPECTED_TABLES=""                    # every name must EXIST and be non-empty in the restore (space-separated; default none)
MIN_RATIO="0.95"                            # restored/live floor for the sentinel table
MAX_RATIO="2.0"                             # restored/live ceiling — catches duplicated/double-restored rows
DRILL_DRIFT_MAX_DROP="0"                    # 0 = off; else fail if a table dropped > this fraction vs the prior passing drill

# Durable-tier verification (verify-durable-pg.ts; the daily caller workflow). Guarantees every
# daily/weekly/monthly object is integrity-tested: PRIMARY hash-checks each new durable object +
# full-restores the freshest daily; SECONDARY full-restores the newest weekly/monthly that is
# >= RETEST_DAYS old and not yet restore-verified. Net: weekly/monthly validated twice, daily once.
DURABLE_PRIMARY="1"                         # on-write leg (hash-check + restore freshest daily)
DURABLE_SECONDARY="1"                       # ~2-week leg (restore aged weekly/monthly)
RETEST_DAYS="14"                            # age at which a weekly/monthly is secondary-due (set 13 to re-test inside the WORM lock)
DURABLE_VERIFY_MAX_RESTORES="2"             # cap full restores per daily run (hash-checks uncapped)

# ── Sanity floor ─────────────────────────────────────────────────────────────
# Abort (don't upload) if the dump is smaller than this — catches a truncated or empty dump. Also
# the staleness check's floor: a fresh-but-smaller object is treated as broken, not just stale.
# Tune up after observing your first real dump size.
MIN_BYTES="1048576"                         # 1 MB

# ── Staleness alert ──────────────────────────────────────────────────────────
# Tolerates one dropped 2-hourly tick without false-alarming (GitHub Actions cron is
# best-effort). check-staleness.ts self-heals a missed tick within the hour.
STALE_HOURS="5"                             # alert if newest 2hourly object is older than this

# ── Slack status row (bot token; see README "Slack") ─────────────────────────
# One message per day, updated in place with a ✅/❌ + HH:MM tick per 2-hourly run.
DISPLAY_TZ="UTC"                            # day boundary + HH:MM labels + tz abbreviation
SLACK_ALERT_MENTION="<!here>"               # prepended to failure alerts (<!here> active members, <!channel> everyone)

# ── Public backup-history dashboard (see README "Dashboard") ─────────────────
# Label defaults to FILE_BASENAME; override with DASHBOARD_LABEL if needed.
# DASHBOARD_LABEL="example"
# DASHBOARD_HIDE_RUN_LINKS="1"              # also drop run links from the public page
# If set, the daily Slack header's "<basename> DB backup" links to the dashboard. The public
# hostname isn't derivable — fetch it once: npx wrangler r2 bucket dev-url get <DASHBOARD_R2_BUCKET>
# DASHBOARD_URL="https://backups.example.com/"
